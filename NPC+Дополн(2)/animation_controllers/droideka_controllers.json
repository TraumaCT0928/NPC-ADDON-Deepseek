{
    "format_version": "1.19.0",
    "animation_controllers": {
        "controller.animation.totr.droideka.movement": {
            "states": {
                "default": {
                    "animations": ["idle"],
                    "transitions": [
                        {
                            "walk": "q.ground_speed > 0.05 && !q.property('totr:is_rolled')"
                        }
                    ],
                    "blend_transition": 0.15
                },
                "walk": {
                    "animations": ["walk"],
                    "transitions": [
                        {
                            "default": "q.ground_speed < 0.01 || q.property('totr:is_rolled')"
                        }
                    ],
                    "blend_transition": 0.15
                }
            }
        },
        "controller.animation.totr.droideka.attack": {
            "states": {
                "default": {
                    "transitions": [
                        {
                            "attack": "q.is_charged"
                        },
                        {
                            "has_target": "q.has_target && !q.property('totr:is_rolled')"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "has_target": {
                    "animations": ["has_target"],
                    "transitions": [
                        {
                            "attack": "q.is_charged"
                        },
                        {
                            "default": "!q.has_target || q.property('totr:is_rolled')"
                        }
                    ],
                    "blend_transition": 0.2
                },
                "attack": {
                    "animations": ["attack"],
                    "transitions": [
                        {
                            "has_target": "q.any_animation_finished && q.has_target && !q.property('totr:is_rolled') && !q.is_charged"
                        },
                        {
                            "default": "q.any_animation_finished && (!q.has_target || q.property('totr:is_rolled'))"
                        }
                    ],
                    "blend_transition": 0.2
                }
            }
        },
        "controller.animation.totr.droideka.recoil": {
            "states": {
                "default": {
                    "transitions": [
                        {
                            "recoil": "v.last_health != q.health && !q.property('totr:is_rolled')"
                        }
                    ]
                },
                "recoil": {
                    "on_entry": [
                        "v.last_hurt = q.life_time;"
                    ],
                    "on_exit": [
                        "v.last_health = q.health;"
                    ],
                    "transitions": [
                        {
                            "default": "q.life_time > v.last_hurt + 0.3"
                        }
                    ]
                }
            }
        },
        "controller.animation.totr.droideka.roll_state": {
            "states": {
                "default": {
                    "animations": ["unrolled_animation"],
                    "transitions": [
                        {
                            "rolling": "q.property('totr:is_rolled')"
                        }
                    ]
                },
                "rolling": {
                    "animations": ["rolled_animation"],
                    "transitions": [
                        {
                            "default": "!q.property('totr:is_rolled')"
                        }
                    ]
                }
            }
        }
    }
}