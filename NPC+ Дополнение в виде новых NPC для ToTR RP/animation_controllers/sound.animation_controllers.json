{
	"format_version": "1.20.10",
	"animation_controllers": {
		"controller.animation.totr.battle_droid.panic.sound": {
			"states": {
				"default": {
					"transitions": [
						{
							"grab": "q.property('totr:force_effect')=='grab'"
						},
						{
							"push": "q.property('totr:force_effect')=='push'"
						},
						{
							"pull": "q.property('totr:force_effect')=='pull'"
						}
					]
				},
				"grab": {
					"animations": [
						"panic_sound_anim"
					],
					"transitions": [
						{
							"default": "q.property('totr:force_effect')!='grab'"
						}
					]
				},
				"push": {
					"transitions": [
						{
							"default": "q.property('totr:force_effect')!='push'"
						}
					]
				},
				"pull": {
					"transitions": [
						{
							"default": "q.property('totr:force_effect')!='pull'"
						}
					]
				}
			}
		},
		"controller.animation.totr.battle_droid.sound.general.rusty": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"death": "!q.is_alive"
						},
						{
							"hurt": "v.is_hurt"
						},
						{
							"attacking": "q.is_delayed_attacking"
						}
					]
				},
				"death": {
					"animations": [
						"death.rusty"
					],
					"transitions": [
						{
							"default": "q.is_alive"
						}
					]
				},
				"hurt": {
					"animations": [
						"hurt.rusty"
					],
					"transitions": [
						{
							"default": "!v.is_hurt"
						}
					]
				},
				"attacking": {
					"animations": [
						"melee.rusty"
					],
					"transitions": [
						{
							"default": "!q.is_delayed_attacking"
						}
					]
				}
			}
		},
		"controller.animation.totr.battle_droid.sound.general.clean": {
			"initial_state": "default",
			"states": {
				"default": {
					"transitions": [
						{
							"death": "!q.is_alive"
						},
						{
							"hurt": "v.is_hurt"
						},
						{
							"attacking": "q.is_delayed_attacking"
						}
					]
				},
				"death": {
					"animations": [
						"death.clean"
					],
					"transitions": [
						{
							"default": "q.is_alive"
						}
					]
				},
				"hurt": {
					"animations": [
						"hurt.clean"
					],
					"transitions": [
						{
							"default": "!v.is_hurt"
						}
					]
				},
				"attacking": {
					"animations": [
						"melee.clean"
					],
					"transitions": [
						{
							"default": "!q.is_delayed_attacking"
						}
					]
				}
			}
		}
	}
}