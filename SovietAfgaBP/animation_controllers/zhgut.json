{
    "format_version": "1.10.0",
    "animation_controllers": {
        "controller.animation.zhgut": {
            "initial_state": "default",
            "states": {
                "default": {
                    "transitions": [
                        {
                            "reload": "query.is_item_name_any('slot.weapon.mainhand',0,'addon:zhgut') && q.is_using_item"
                        }
                    ]
                },
                "reload": {
                    "animations": [
                        "zhgutuse"
                    ],
                    "transitions": [
                        {
                            "default": "query.all_animations_finished"
                        }
                    ]
                }
            }
        }
    }
}