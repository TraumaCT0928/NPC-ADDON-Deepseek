{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.dshkm_fire": {
      "states": {
        "default": {
          "transitions": [
            {
              "reload": "query.equipped_item_any_tag('slot.weapon.mainhand','dshkm_mag') && query.is_using_item && query.is_riding"
            },
            {
              "fire": "query.equipped_item_any_tag('slot.weapon.mainhand','lenta12.7') && query.is_using_item && query.is_riding && query.scoreboard('trasser') != 1"
            },
            {
              "fire2": "query.equipped_item_any_tag('slot.weapon.mainhand','lenta12.7') && query.is_using_item && query.is_riding && query.scoreboard('trasser') == 1"
            },
            {
              "working0": "query.is_riding && !query.is_using_item"
            },
            {
              "working1": "!query.is_riding && query.mark_variant != 5"
            }
          ]
        },
        "reload": {
          "animations": ["dshkmreload"],
          "transitions": [
            {
  "default":"query.all_animations_finished"
  }
          ]
        },
        "working0": {
          "transitions": [
            {
              "default": "1.0"
            }
          ],
          "on_entry": [
            "/execute @e[tag=dshk_empty,type=addon:dshkm,r=2] ~~~ clear @a[tag=riding,r=2] addon:lenta12.7",
            "/execute @e[type=addon:dshkm,r=2] ~~~ tag @a[tag=riding,r=2] add dshkm",
            "/execute @e[tag=!dshk_empty,type=addon:dshkm,r=2] ~~~ give @a[tag=dshkm,tag=!hui] addon:lenta12.7 1 1 {\"minecraft:item_lock\":{ \"mode\": \"lock_in_inventory\" }}",
            "/tag @s[tag=dshkm] add hui",
            "/fill ~3~2~3 ~-3~-2~-3 air 0 replace light_block",
            "/event entity @s[tag=dshkm] dshkm"
          ]
        },
        "fire": {
          "transitions": [
            {
              "default": "1.0"
            },
            {
              "unfire": "1.0"
            }
          ],
          "on_entry": [
            "/scoreboard objectives add trasser dummy",
            "/scoreboard players set @s trasser 1",
            "/execute @e[type=addon:dshkm,r=1] ~ ~ ~ event entity @a[tag=dshkm,r=2] 12.7x108_trasser_bullet",
            "/tag @s remove trasser",
            "/tag @s[tag=!trasser] add trasser",
            "/execute @e[tag=dshk_empty,type=addon:dshkm,r=2] ~~~ clear @a[tag=riding,r=2] addon:lenta12.7",
            "/scoreboard objectives add dshkm dummy",
          "/scoreboard players add @e[type=addon:dshkm,r=2] dshkm 1",
          "/tag @e[type=addon:dshkm,r=2,scores={dshkm=50..10000}] add dshk_empty",
          "/scoreboard players set @e[type=addon:dshkm,r=2,scores={dshkm=50..10000}] dshkm 0",
            "/playsound addon.dshkm @a ^^^0.10 300 1",
            "/playanimation @s animation.dshkm_fire",
            "/camerashake add @s 0.075 0.05 rotational"
          ]
        },
        "fire2": {
          "transitions": [
            {
              "default": "1.0"
            },
            {
              "unfire": "1.0"
            }
          ],
          "on_entry": [
            "/scoreboard objectives add trasser dummy",
            "/scoreboard players set @s trasser 0",
            "/tag @s remove trasser",
            "/execute @e[type=addon:dshkm,r=1] ~ ~ ~ event entity @a[tag=dshkm,r=2] 12.7x108_bullet",
            "/tag @s[tag=!trasser] add trasser",
            "/execute @e[tag=dshk_empty,type=addon:dshkm,r=2] ~~~ clear @a[tag=riding,r=2] addon:lenta12.7",
            "/scoreboard objectives add dshkm dummy",
          "/scoreboard players add @e[type=addon:dshkm,r=2] dshkm 1",
          "/tag @e[type=addon:dshkm,r=2,scores={dshkm=50..10000}] add dshk_empty",
          "/scoreboard players set @e[type=addon:dshkm,r=2,scores={dshkm=50..10000}] dshkm 0",
            "/playsound addon.dshkm @a ^^^0.10 300 1",
            "/playanimation @s animation.dshkm_fire",
            "/camerashake add @s 0.075 0.05 rotational"
          ]
        },
        "unfire": {
          "transitions": [
            {
              "default": "1.0"
            }
          ],
          "on_entry": [
            "/fill ~3~2~3 ~-3~-2~-3 air 0 replace light_block"
          ]
        },
        "working1": {
          "transitions": [
            {
              "default": "1.0"
            }
          ],
          "on_entry": [
            "/tag @s remove dshkm",
            "@s off",
            "/clear @s addon:lenta12.7"
          ]
        }
      }
    }
  }
}
