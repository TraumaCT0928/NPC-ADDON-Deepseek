          {"akms_controller": "variable.ak && variable.is_first_person && !query.equipped_item_any_tag('slot.weapon.mainhand','gp25') && !query.equipped_item_any_tag('slot.weapon.mainhand','gp25_fire')"},
          {"akms_gp_controller_2": "variable.ak && variable.is_first_person && query.equipped_item_any_tag('slot.weapon.mainhand','gp25_fire')"},
          {"akms_gp_controller": "variable.ak && variable.is_first_person && !query.equipped_item_any_tag('slot.weapon.mainhand','gp25_fire') && query.equipped_item_any_tag('slot.weapon.mainhand','gp25')"},
          {"akms_controller_third": "variable.ak && !query.is_riding && !variable.is_first_person"},
          {"svd_controller_third": "variable.svd && !query.is_riding && !variable.is_first_person"},
          {"svd_controller": "variable.svd && variable.is_first_person && !query.equipped_item_any_tag('slot.weapon.mainhand','nspu') && !query.equipped_item_any_tag('slot.weapon.mainhand','pso1')"},
