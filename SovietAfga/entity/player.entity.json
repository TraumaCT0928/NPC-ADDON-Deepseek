          "variable.f1 = query.equipped_item_any_tag('slot.weapon.mainhand','f1');"
        ],
        "animate": [
          "root",
          {"f1_controller": "variable.f1 && variable.is_first_person"},
          {"ai1m_controller": "variable.is_first_person && !variable.f1 && variable.ai1m"},
          {"ai1m_controller_third": "!variable.is_first_person && !variable.f1 && variable.ai1m"},
          {"zhgut_controller": "variable.is_first_person && variable.zhgut"},
          {"zhgut_controller_third": "!variable.is_first_person && variable.zhgut"},
