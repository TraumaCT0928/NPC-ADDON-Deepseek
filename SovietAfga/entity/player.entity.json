          {"pm_controller": "variable.pm && variable.is_first_person"},
          {"pm_controller_third": "variable.guns && !variable.ai1m && variable.pm && !variable.rpg7v && !variable.is_first_person"},
          {"pm_controller_third": "variable.guns && !variable.ai1m && variable.aps && !variable.rpg7v && !variable.is_first_person"},
          {"aps_flash": "variable.aps"},
          {"aps_controller": "variable.aps && variable.is_first_person"},
          {"pkm_controller": "variable.pkm && variable.is_first_person"},
          {"pkm_third": "variable.pkm && !variable.is_first_person && !query.is_riding"},
          {"rpk_soshki": "variable.rpk74 && query.is_riding"},
          {"aks74u_flash": "variable.aks74u"},
          {"pkm_controller_third": "variable.pkm && !query.is_riding && !variable.is_first_person"},
