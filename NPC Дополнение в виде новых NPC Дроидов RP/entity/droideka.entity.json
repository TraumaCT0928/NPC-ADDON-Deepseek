{
	"format_version": "1.19.0",
	"minecraft:client_entity": {
		"description": {
			"identifier": "totr:droideka",
			"spawn_egg": {
				"base_color": "#505058",
				"overlay_color": "#61482b"
			},
			"materials": {
				"default": "entity_alphatest",
				"shield": "entity_flat_additive"
			},
			"textures": {
				"default": "textures/entity/droideka/droideka",
				"shield": "textures/entity/droideka/droideka_shield"
			},
			"geometry": {
				"default": "geometry.totr.droideka",
				"shield": "geometry.totr.droideka_shield"
			},
			"render_controllers": [
				"controller.render.totr.droideka",
				{
					"controller.render.totr.droideka_shield": "q.is_sheared&&!q.property('totr:is_rolled')"
				}
			],
			"animations": {
				"idle": "animation.totr.droideka.idle",
				"walk": "animation.totr.droideka.walk",
				"attack": "animation.totr.droideka.attack",
				"has_target": "animation.totr.droideka.has_target",
				"shield": "animation.totr.droideka.shield",
				"rolled_animation": "animation.totr.droideka.test_rolling",
				"unrolled_animation": "animation.totr.droideka.test",
				"roll_controller": "controller.animation.totr.droideka.roll_state",
				"movement_controller": "controller.animation.totr.droideka.movement",
				"attack_controller": "controller.animation.totr.droideka.attack",
				"recoil_controller": "controller.animation.totr.droideka.recoil"
			},
			"scripts": {
				"initialize": [
					"v.recoil_dir = 3;",
					"v.last_health = q.health;",
					"v.last_hurt = -100;",
					"v.hurt_overlay = 0;"
				],
				"pre_animation": [
					"v.hurt_overlay = Math.clamp(1 - (q.life_time - v.last_hurt)/0.3, 0, 1);"
				],
				"animate": [
					"roll_controller",
					{
						"movement_controller": "!q.property('totr:is_rolled')"
					},
					{
						"attack_controller": "!q.property('totr:is_rolled')"
					},
					{
						"recoil_controller": "!q.property('totr:is_rolled')"
					},
					{
						"shield": "q.is_sheared&&!q.property('totr:is_rolled')"
					}
				]
			},
			"sound_effects": {
				"step_sound": "droideka_step",
				"shield_broken_sound": "droideka_shield_destroyed"
			}
		}
	}
}